# =============================================================================
# Förderverein IWI – Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.
# =============================================================================

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# SMTP-Konfiguration (für E-Mail-Versand)
# Ohne SMTP werden Formular-Daten nur in der Konsole geloggt.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=info@iwi-hs-niederrhein.de

# Empfänger-Adresse für Kontakt- und Mitgliedschaftsanfragen
CONTACT_EMAIL=info@iwi-hs-niederrhein.de
